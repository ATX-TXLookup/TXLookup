# See docs/setup.md for what each of these is for and where to get it.
# Never commit a filled-in .env — it's gitignored already.

# OpenAI / Codex — required for the planner. $50 credit code emailed at kickoff.
OPENAI_API_KEY=

# Miro — most Miro work goes through MCP, not REST. Token only needed if your
# code calls the Miro REST API directly. Board ID needed if we pre-create one.
MIRO_API_TOKEN=
MIRO_BOARD_ID=

# Socrata — optional but strongly recommended. Without auth you share a
# low public rate limit. Sign up at https://evergreen.data.socrata.com/signup,
# then Profile → Edit Profile → Developer Settings → generate API key.
# Docs: https://dev.socrata.com/docs/app-tokens.html
SOCRATA_KEY_ID=
SOCRATA_KEY_SECRET=

# Featherless — unlimited free open-source model inference. Setup PDF
# distributed at the event.
FEATHERLESS_API_KEY=

# Supabase — only needed if your issue touches caching/storage. Not v1.
SUPABASE_URL=
SUPABASE_KEY=

# Fal.ai — image/video generation. Not in scope for v1 (other track).
FAL_API_KEY=

# Google Analytics 4 — set this in the Vercel project env (Production +
# Preview), not locally. If unset the GA component renders nothing, so dev
# stays clean. Format: G-XXXXXXXXXX. See docs/analytics.md.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
