# See docs/setup.md for what each of these is for and where to get it.
# Never commit a filled-in .env — it's gitignored already.

# OpenAI / Codex — required for the planner. $50 credit code emailed at kickoff.
OPENAI_API_KEY=

# Miro — most Miro work goes through MCP, not REST. Token only needed if your
# code calls the Miro REST API directly. Board ID needed if we pre-create one.
MIRO_API_TOKEN=
MIRO_BOARD_ID=

# Socrata — optional. Without a token you share a low public rate limit;
# with one you get higher per-app limits. Free at:
# https://opendata.socrata.com/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Featherless — unlimited free open-source model inference. Setup PDF
# distributed at the event.
FEATHERLESS_API_KEY=

# Supabase — only needed if your issue touches caching/storage. Not v1.
SUPABASE_URL=
SUPABASE_KEY=

# Fal.ai — image/video generation. Not in scope for v1 (other track).
FAL_API_KEY=
